{
  "manifest_version": 3,
  "name": "Excel Engine",
  "version": "1.2.0",
  "description": "Autonomous Excel automation — upload workbooks and instructions, get completed assignments back.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:8080/*"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "popup/options.html"
}
